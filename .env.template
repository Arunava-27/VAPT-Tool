# =============================================================================
# VAPT Platform Environment Configuration
# =============================================================================
# Copy this file to .env and update the values according to your environment
# DO NOT commit .env file to version control (already in .gitignore)
# =============================================================================

# =============================================================================
# DEPLOYMENT MODE
# =============================================================================
# Options: development, production, air-gapped
DEPLOYMENT_MODE=development

# Environment (dev, staging, production)
ENVIRONMENT=development

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION (PostgreSQL)
# =============================================================================
POSTGRES_DB=vapt_platform
POSTGRES_USER=vapt_user
POSTGRES_PASSWORD=changeme123

# Full database URL (constructed from above or override)
# DATABASE_URL=postgresql://vapt_user:changeme123@postgres:5432/vapt_platform

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_PASSWORD=redis123
# REDIS_URL=redis://:redis123@redis:6379/0

# =============================================================================
# MESSAGE QUEUE (RabbitMQ)
# =============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
# RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# =============================================================================
# OBJECT STORAGE (MinIO)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# =============================================================================
# SUPER ADMIN (auto-created / password synced on every container start)
# =============================================================================
# Change these after first deployment. Password is synced on every restart
# so updating SUPERUSER_PASSWORD here and restarting api-gateway is enough.
SUPERUSER_EMAIL=admin@vapt-platform.local
SUPERUSER_PASSWORD=Admin@123

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# JWT Secret Key - CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=supersecretkey-changeme-use-openssl-rand-hex-32

# JWT Algorithm (HS256 or RS256)
JWT_ALGORITHM=HS256

# Token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
PASSWORD_HASH_ALGORITHM=bcrypt
PASSWORD_MIN_LENGTH=8

# =============================================================================
# API GATEWAY CONFIGURATION
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# API rate limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_MINUTE_UNAUTH=20

# API versioning
API_VERSION=v1

# =============================================================================
# AI / LLM CONFIGURATION
# =============================================================================
# Primary LLM Provider (openai, anthropic, ollama, local)
LLM_PROVIDER=ollama

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (Local LLM) Configuration
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:latest

# LLM Fallback Strategy
LLM_FALLBACK_ENABLED=true
# Fallback order: primary -> secondary -> tertiary
LLM_FALLBACK_PROVIDERS=openai,ollama

# AI Agent Configuration
AI_AGENT_TIMEOUT_SECONDS=300
AI_AGENT_MAX_RETRIES=3
AI_AGENT_TEMPERATURE=0.7

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================
# Celery worker concurrency
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# Task timeout settings (seconds)
TASK_TIMEOUT_NMAP=600
TASK_TIMEOUT_ZAP=1800
TASK_TIMEOUT_TRIVY=300
TASK_TIMEOUT_PROWLER=900
TASK_TIMEOUT_METASPLOIT=1200

# =============================================================================
# NMAP WORKER CONFIGURATION
# =============================================================================
NMAP_DEFAULT_PORTS=1-1000
NMAP_DEFAULT_TIMEOUT=60
NMAP_MAX_PARALLEL_SCANS=5

# =============================================================================
# ZAP WORKER CONFIGURATION
# =============================================================================
ZAP_PORT=8080
ZAP_API_KEY=
ZAP_MAX_DEPTH=5
ZAP_MAX_CHILDREN=10

# =============================================================================
# TRIVY WORKER CONFIGURATION
# =============================================================================
TRIVY_DB_REPOSITORY=ghcr.io/aquasecurity/trivy-db
TRIVY_SEVERITY=CRITICAL,HIGH,MEDIUM
TRIVY_CACHE_DIR=/tmp/trivy-cache

# =============================================================================
# PROWLER WORKER CONFIGURATION
# =============================================================================
# AWS Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Azure Configuration
AZURE_SUBSCRIPTION_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# GCP Configuration
GOOGLE_APPLICATION_CREDENTIALS=

# =============================================================================
# METASPLOIT WORKER CONFIGURATION
# =============================================================================
MSF_RPC_HOST=localhost
MSF_RPC_PORT=55553
MSF_RPC_SSL=true
MSF_RPC_TOKEN=

# =============================================================================
# ELASTICSEARCH CONFIGURATION
# =============================================================================
ELASTICSEARCH_URL=http://elasticsearch:9200
# Elasticsearch memory settings
ES_JAVA_OPTS=-Xms512m -Xmx512m

# =============================================================================
# PRIVATE NETWORK CONFIGURATION
# =============================================================================
# Proxy settings for outbound connections
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis,rabbitmq,minio,elasticsearch

# Air-gapped mode (disable external API calls)
AIRGAP_MODE=false

# Custom CA certificates path
CUSTOM_CA_CERTS_PATH=/certs/ca-bundle.crt

# Update server for air-gapped environments
UPDATE_SERVER_URL=

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000

# Frontend features
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Prometheus
PROMETHEUS_ENABLED=false

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# =============================================================================
# MULTI-TENANCY CONFIGURATION
# =============================================================================
# Enable multi-tenant mode
MULTI_TENANT_ENABLED=true

# Tenant isolation strategy (schema, database, discriminator)
TENANT_ISOLATION_STRATEGY=schema

# Default tenant for single-tenant deployments
DEFAULT_TENANT_ID=default

# =============================================================================
# LICENSING (for private deployments)
# =============================================================================
LICENSE_KEY=
LICENSE_VALIDATION_URL=
LICENSE_OFFLINE_MODE=true

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_AI_AGENTS_ENABLED=true
FEATURE_AUTO_EXPLOITATION_ENABLED=false
FEATURE_CLOUD_SCANNING_ENABLED=true
FEATURE_API_RATE_LIMITING_ENABLED=true
FEATURE_AUDIT_LOGGING_ENABLED=true

# =============================================================================
# SCAN CONFIGURATION
# =============================================================================
# Maximum concurrent scans per tenant
MAX_CONCURRENT_SCANS_PER_TENANT=5

# Scan result retention (days)
SCAN_RESULT_RETENTION_DAYS=90

# Auto-cleanup old scans
AUTO_CLEANUP_ENABLED=true

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
# Email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@vapt-platform.local
SMTP_USE_TLS=true

# Slack notifications
SLACK_WEBHOOK_URL=

# Webhook notifications
WEBHOOK_NOTIFICATION_URL=

# =============================================================================
# DOCKER COMPOSE PROFILES
# =============================================================================
# To start specific services:
# docker-compose --profile api up -d
# docker-compose --profile workers up -d
# docker-compose --profile monitoring up -d
#
# Available profiles:
# - api: API Gateway and Orchestrator
# - workers: All security tool workers
# - ai: AI Engine and Ollama
# - frontend: React frontend
# - monitoring: Prometheus and Grafana
# - local-llm: Ollama for local LLM
